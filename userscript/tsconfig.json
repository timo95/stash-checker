{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strict": true,
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2024",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2024", "dom"],
    "sourceMap": true,
    "noUncheckedSideEffectImports": false,
    "libReplacement": true,
    "resolveJsonModule": true,
    "types": ["greasemonkey"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
